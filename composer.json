{
  "name": "andrekelling/kirby-block-finder",
  "description": "Block Finder",
  "homepage:": "https://github.com/AndreKelling/kirby-block-finder/",
  "license": "MIT",
  "type": "kirby-plugin",
  "version": "1.0.0",
  "authors": [
    {
      "name": "André Kelling",
      "email": "kontakt@andrekelling.de"
    }
  ],
  "require": {
    "getkirby/composer-installer": "^1.2"
  },
  "require-dev": {
    "getkirby/cms": "^5.1"
  },
  "autoload": {
    "psr-4": {
      "BlockFinder\\": "classes/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  },
  "scripts": {
    "dist": [
      "npm run build",
      "composer install --no-dev --optimize-autoloader"
    ]
  }
}
